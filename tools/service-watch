#!/bin/bash

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# ServiceWatch

LOG_FILE="$HOME/service-watch.log"

# Functions

validate_arguments() {
    if [ "$#" -lt 1 ]; then
        echo "Usage: $0 service_name [service_name ...]"
        exit 1
    fi
}

resolve_service_name() {
    local input="$1"

    if /usr/bin/systemctl list-unit-files --type=service | grep -q "^${input}.service"; then
        echo "$input"
        return 0
    fi

    if /usr/bin/systemctl list-unit-files --type=service | grep -q "^${input}d.service"; then
        echo "${input}d"
        return 0
    fi

    return 1
}

log_service_issue() {
    local service="$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') Service '$service' is NOT running" >> "$LOG_FILE"
}

check_service_status() {
    local service="$1"

    if /usr/bin/systemctl is-active --quiet "$service"; then
        echo "Service '$service' is running"
        return 0
    else
        echo "Service '$service' is NOT running"
        log_service_issue "$service"
        return 1
    fi
}

# Main

main() {
    validate_arguments "$@"

    for input in "$@"; do
        service=$(resolve_service_name "$input")

        if [ -z "$service" ]; then
            echo "Service '$input' does not exist"
            continue
        fi

        check_service_status "$service"
    done
}

main "$@"
